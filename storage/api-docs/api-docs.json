{
    "openapi": "3.0.0",
    "info": {
        "title": "API Plataforma de Cursos",
        "description": "API para gestionar cursos, instructores, lecciones, comentarios, calificaciones y favoritos.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "Servidor local"
        }
    ],
    "paths": {
        "/api/courses": {
            "get": {
                "tags": [
                    "Courses"
                ],
                "summary": "Lista cursos e instructores",
                "operationId": "listCourses",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    },
                    {
                        "name": "instructors_per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 100
                        }
                    },
                    {
                        "name": "instructors_cursor",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Listado paginado de cursos e instructores"
                    }
                }
            },
            "post": {
                "tags": [
                    "Courses"
                ],
                "summary": "Crea un curso",
                "operationId": "storeCourse",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "instructor_id",
                                    "title",
                                    "description",
                                    "price",
                                    "level"
                                ],
                                "properties": {
                                    "instructor_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "title": {
                                        "type": "string",
                                        "example": "Laravel desde cero"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Curso completo para aprender Laravel 12 desde cero."
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 29.99
                                    },
                                    "level": {
                                        "type": "string",
                                        "example": "beginner"
                                    },
                                    "is_published": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Curso creado"
                    },
                    "422": {
                        "description": "Error de validacion"
                    }
                }
            }
        },
        "/api/courses/{course}": {
            "get": {
                "tags": [
                    "Courses"
                ],
                "summary": "Obtiene un curso",
                "operationId": "showCourse",
                "parameters": [
                    {
                        "name": "course",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Curso encontrado"
                    },
                    "404": {
                        "description": "Curso no encontrado"
                    }
                }
            },
            "put": {
                "tags": [
                    "Courses"
                ],
                "summary": "Actualiza un curso",
                "operationId": "updateCourse",
                "parameters": [
                    {
                        "name": "course",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "instructor_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "title": {
                                        "type": "string",
                                        "example": "Laravel avanzado"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Contenido actualizado del curso."
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 59.99
                                    },
                                    "level": {
                                        "type": "string",
                                        "example": "advanced"
                                    },
                                    "is_published": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Curso actualizado"
                    },
                    "422": {
                        "description": "Error de validacion"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Courses"
                ],
                "summary": "Elimina un curso",
                "operationId": "destroyCourse",
                "parameters": [
                    {
                        "name": "course",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Curso eliminado"
                    }
                }
            }
        },
        "/api/courses/{course}/average-rating": {
            "get": {
                "tags": [
                    "Courses"
                ],
                "summary": "Promedio de rating del curso",
                "operationId": "courseAverageRating",
                "parameters": [
                    {
                        "name": "course",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Promedio calculado"
                    }
                }
            }
        },
        "/api/instructors": {
            "get": {
                "tags": [
                    "Instructors"
                ],
                "summary": "Lista instructores",
                "operationId": "listInstructors",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 15
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Listado de instructores"
                    }
                }
            },
            "post": {
                "tags": [
                    "Instructors"
                ],
                "summary": "Crea un instructor",
                "operationId": "storeInstructor",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Ana Martinez"
                                    },
                                    "headline": {
                                        "type": "string",
                                        "example": "Senior Backend Engineer"
                                    },
                                    "bio": {
                                        "type": "string",
                                        "example": "Instructora con experiencia en Laravel y arquitectura de software."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Instructor creado"
                    },
                    "422": {
                        "description": "Error de validacion"
                    }
                }
            }
        },
        "/api/instructors/{instructor}": {
            "get": {
                "tags": [
                    "Instructors"
                ],
                "summary": "Obtiene un instructor",
                "operationId": "showInstructor",
                "parameters": [
                    {
                        "name": "instructor",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Instructor encontrado"
                    }
                }
            },
            "put": {
                "tags": [
                    "Instructors"
                ],
                "summary": "Actualiza un instructor",
                "operationId": "updateInstructor",
                "parameters": [
                    {
                        "name": "instructor",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Ana Martinez Updated"
                                    },
                                    "headline": {
                                        "type": "string",
                                        "example": "Lead Backend Engineer"
                                    },
                                    "bio": {
                                        "type": "string",
                                        "example": "Actualizacion del perfil del instructor."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Instructor actualizado"
                    },
                    "422": {
                        "description": "Error de validacion"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Instructors"
                ],
                "summary": "Elimina un instructor",
                "operationId": "destroyInstructor",
                "parameters": [
                    {
                        "name": "instructor",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Instructor eliminado"
                    }
                }
            }
        },
        "/api/users/{user}/favorite-courses/{course}": {
            "post": {
                "tags": [
                    "Interactions"
                ],
                "summary": "Marca curso como favorito",
                "operationId": "favoriteCourse",
                "parameters": [
                    {
                        "name": "user",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "course",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Curso marcado como favorito"
                    }
                }
            },
            "delete": {
                "tags": [
                    "Interactions"
                ],
                "summary": "Desmarca curso como favorito",
                "operationId": "unfavoriteCourse",
                "parameters": [
                    {
                        "name": "user",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "course",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Curso removido de favoritos"
                    }
                }
            }
        },
        "/api/courses/{course}/comments": {
            "post": {
                "tags": [
                    "Interactions"
                ],
                "summary": "Comenta un curso",
                "operationId": "commentCourse",
                "parameters": [
                    {
                        "name": "course",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "user_id",
                                    "body"
                                ],
                                "properties": {
                                    "user_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "body": {
                                        "type": "string",
                                        "example": "Excelente curso de Laravel."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Comentario creado"
                    }
                }
            }
        },
        "/api/instructors/{instructor}/comments": {
            "post": {
                "tags": [
                    "Interactions"
                ],
                "summary": "Comenta un instructor",
                "operationId": "commentInstructor",
                "parameters": [
                    {
                        "name": "instructor",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "user_id",
                                    "body"
                                ],
                                "properties": {
                                    "user_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "body": {
                                        "type": "string",
                                        "example": "Muy buen instructor."
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Comentario creado"
                    }
                }
            }
        },
        "/api/courses/{course}/ratings": {
            "post": {
                "tags": [
                    "Interactions"
                ],
                "summary": "Califica un curso",
                "operationId": "rateCourse",
                "parameters": [
                    {
                        "name": "course",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "user_id",
                                    "score"
                                ],
                                "properties": {
                                    "user_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "score": {
                                        "type": "integer",
                                        "example": 5,
                                        "maximum": 5,
                                        "minimum": 1
                                    },
                                    "review": {
                                        "type": "string",
                                        "example": "Muy completo"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Calificacion registrada"
                    }
                }
            }
        },
        "/api/instructors/{instructor}/ratings": {
            "post": {
                "tags": [
                    "Interactions"
                ],
                "summary": "Califica un instructor",
                "operationId": "rateInstructor",
                "parameters": [
                    {
                        "name": "instructor",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
